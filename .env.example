# Required secrets
GNEWS_API_KEY=your-gnews-key
LLM_API_KEY=your-llm-key
MONGODB_URI=your-atlas-connection-string

# Optional acquisition tuning (§7) — defaults shown; safe to omit.
# ARTICLES_PER_QUERY=10
# GNEWS_SORT=publishedAt          # publishedAt is required on the GNews free tier (30-day window); relevance returns empty
# SEARCH_TTL_SECONDS=600          # search cache freshness (10 min)
# FETCHED_ARTICLE_TTL_SECONDS=86400   # unanalyzed-article eviction (24h)
